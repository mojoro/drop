# Drop — environment variables
# Copy this file to .env.local and fill in at least one LLM backend.
#
#   cp .env.example .env.local

# ── LLM Backends ──────────────────────────────────────────────────────────────
# Auto mode tries backends in order: Ollama → OpenRouter → Featherless → Claude.
# Configure at least one.

# Local — requires Ollama running with a model pulled
# Pull a model first:  ollama pull qwen2.5:7b
OLLAMA_MODEL=                         # e.g. qwen2.5:7b
OLLAMA_URL=http://localhost:11434     # Docker users: use http://host.docker.internal:11434

# Cloud — recommended if you don't want to run a local model
OPENROUTER_API_KEY=                   # https://openrouter.ai — many models, free tier available
FEATHERLESS_API_KEY=                  # https://featherless.ai
ANTHROPIC_API_KEY=                    # Claude Haiku 4.5 — used as last fallback

# ── TTS Backends ───────────────────────────────────────────────────────────────
# Local TTS (pocket-tts sidecar) is the default — no key needed.
# For multilanguage or higher-quality voices, use a cloud backend.

ELEVENLABS_API_KEY=                   # https://elevenlabs.io — best quality, multilanguage
OPENAI_API_KEY=                       # OpenAI TTS voices

# ── Optional ───────────────────────────────────────────────────────────────────
NEEDLE_API_KEY=                       # Fallback web scraper — built-in Readability is used by default

# Managed automatically by Docker Compose. Override only if running sidecars manually on different ports.
TTS_SERVER_URL=http://localhost:8000
QWEN_TTS_SERVER_URL=http://localhost:8001  # Qwen3-TTS sidecar (qwen-tts-server/)

# AES-256-GCM key for encrypting settings profiles. Auto-generated and saved to data/.key if not set.
DROP_ENCRYPTION_KEY=
